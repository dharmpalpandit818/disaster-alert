<!DOCTYPE html>
<html lang="<%= lang %>">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= t.alerts.title %> — <%= t.meta.siteTitle %></title>
    <link rel="shortcut icon" href="https://img.freepik.com/free-vector/globe-fire-melting_78370-7954.jpg?semt=ais_hybrid&w=740&q=80" type="image/x-icon">
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body>
<%- include('../partials/navbar') %>

<div class="container main-content">
    <h2 class="section-title"><i class="fas fa-bell"></i> <%= t.alerts.title %></h2>
    <% if (typeof error !== 'undefined' && error) { %>
        <div class="alert error"><%= error %></div>
    <% } %>
    <% if (alerts && alerts.length > 0) { %>
        <div class="alerts-list">
            <% alerts.forEach(function(alert) { %>
                <% var sev = String(alert.severity || '').toLowerCase(); %>
                <div class="alert-item <%= sev %>">
                    <div class="alert-item-thumb">
                        <%- include('../partials/disaster-photo', { disasterType: alert.type, imgClass: 'alert-list-thumb-img' }) %>
                    </div>
                    <div class="alert-item-main">
                        <div class="alert-item-top">
                            <span class="alert-severity-badge <%= sev %>"><%= alert.severity %></span>
                        </div>
                        <div class="alert-content">
                            <h3><%= alert.title %></h3>
                            <div class="alert-meta">
                                <span><i class="fas fa-<%= getAlertFaIcon(alert.type) %>"></i> <%= alert.type %></span>
                                <span><i class="fas fa-map-marker-alt"></i> <%= alert.location %></span>
                                <span><i class="fas fa-clock"></i> <%= alert.createdAt.toLocaleString('en-IN', { timeZone: 'Asia/Kolkata', dateStyle: 'medium', timeStyle: 'short' }) %></span>
                            </div>
                            <p class="alert-item-desc"><%= alert.description %></p>
                        </div>
                        <a href="/alerts/<%= alert._id %>" class="btn btn-primary alert-item-btn"><%= t.alerts.details %></a>
                    </div>
                </div>
            <% }); %>
        </div>
    <% } else { %>
        <div class="empty-state">
            <i class="fas fa-check-circle"></i>
            <p><%= t.alerts.noAlerts %></p>
        </div>
    <% } %>
</div>

<%- include('../partials/footer') %>
</body>
</html>
