<!DOCTYPE html>
<html lang="<%= lang %>">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= alert.title %> — <%= t.meta.siteTitle %></title>
    <link rel="shortcut icon" href="https://img.freepik.com/free-vector/globe-fire-melting_78370-7954.jpg?semt=ais_hybrid&w=740&q=80" type="image/x-icon">
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body>
<%- include('../partials/navbar') %>

<div class="container main-content">
    <div class="alert-detail-card <%= String(alert.severity || '').toLowerCase() %>">
        <div class="alert-detail-hero">
            <%- include('../partials/disaster-photo', { disasterType: alert.type, imgClass: 'alert-detail-hero-img' }) %>
        </div>
        <div class="alert-detail-inner">
            <div class="alert-detail-header">
                <span class="severity-badge-large <%= String(alert.severity || '').toLowerCase() %>"><%= alert.severity %></span>
                <span class="type-badge">
                    <i class="fas fa-<%= getAlertFaIcon(alert.type) %>"></i> <%= alert.type %>
                </span>
            </div>
            <h1><%= alert.title %></h1>
            <div class="alert-detail-meta">
                <p><i class="fas fa-map-marker-alt"></i> <strong><%= t.common.location %>:</strong> <%= alert.location %></p>
                <p><i class="fas fa-clock"></i> <strong><%= t.common.issued %>:</strong> <%= alert.createdAt.toLocaleString() %></p>
            </div>
            <div class="alert-detail-section">
                <h3><i class="fas fa-info-circle"></i> <%= t.common.description %></h3>
                <p><%= alert.description %></p>
            </div>
            <div class="alert-detail-section safety-box">
                <h3><i class="fas fa-shield-alt"></i> <%= t.common.safetyInstructions %></h3>
                <p><%= alert.safetyInstructions %></p>
            </div>
            <div class="alert-detail-actions">
                <a href="/alerts" class="btn btn-secondary"><i class="fas fa-arrow-left"></i> <%= t.common.backToAlerts %></a>
                <a href="/safety/<%= alert.type %>" class="btn btn-primary"><i class="fas fa-book-open"></i> <%= t.common.fullGuide %></a>
            </div>
        </div>
    </div>
</div>

<%- include('../partials/footer') %>
</body>
</html>
