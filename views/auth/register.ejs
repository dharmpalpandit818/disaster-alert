<!DOCTYPE html>
<html lang="<%= lang %>">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= t.auth.registerTitle %> — <%= t.meta.siteTitle %></title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body>
<%- include('../partials/navbar') %>

<div class="container main-content auth-wrap">
    <div class="auth-card">
        <h1><i class="fas fa-user-plus"></i> <%= t.auth.registerTitle %></h1>
        <% if (typeof error !== 'undefined' && error) { %><div class="alert error"><%= error %></div><% } %>
        <form action="/auth/register" method="POST" class="auth-form">
            <div class="form-group">
                <label for="name"><%= t.auth.name %></label>
                <input id="name" type="text" name="name" required value="<%= values.name || '' %>" autocomplete="name">
            </div>
            <div class="form-group">
                <label for="email"><%= t.auth.email %></label>
                <input id="email" type="email" name="email" required value="<%= values.email || '' %>" autocomplete="email">
            </div>
            <div class="form-group">
                <label for="phone"><%= t.auth.phone %></label>
                <input id="phone" type="tel" name="phone" placeholder="+91xxxxxxxxxx" value="<%= values.phone || '' %>" autocomplete="tel">
            </div>
            <div class="form-group">
                <label for="preferredLanguage"><%= t.subscribe.language %></label>
                <select id="preferredLanguage" name="preferredLanguage" class="lang-select">
                    <% supportedLangs.forEach(function(l) { %>
                        <option value="<%= l.code %>" <%= ((values && values.preferredLanguage === l.code) || (!(values && values.preferredLanguage) && lang === l.code)) ? 'selected' : '' %>><%= l.label %></option>
                    <% }); %>
                </select>
            </div>
            <div class="form-group">
                <label for="password"><%= t.auth.password %></label>
                <input id="password" type="password" name="password" required minlength="8" autocomplete="new-password">
            </div>
            <div class="form-group">
                <label for="confirmPassword"><%= t.auth.confirmPassword %></label>
                <input id="confirmPassword" type="password" name="confirmPassword" required minlength="8" autocomplete="new-password">
            </div>
            <button type="submit" class="btn btn-primary btn-block"><%= t.auth.submitRegister %></button>
        </form>
        <p class="auth-switch"><a href="/auth/login"><%= t.auth.haveAccount %></a></p>
    </div>
</div>

<%- include('../partials/footer') %>
</body>
</html>
