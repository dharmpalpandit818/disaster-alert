<!DOCTYPE html>
<html lang="<%= lang %>">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= t.meta.siteTitle %></title>
    <link rel="shortcut icon" href="https://img.freepik.com/free-vector/globe-fire-melting_78370-7954.jpg?semt=ais_hybrid&w=740&q=80" type="image/x-icon">
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body>
<%- include('partials/navbar') %>

<section class="hero-section">
    <div class="hero-overlay" aria-hidden="true"></div>
    <div class="container hero-inner">
        <p class="hero-eyebrow"><i class="fas fa-shield-halved"></i> <%= t.nav.brand %></p>
        <h1 class="hero-title"><%= t.home.heroTitle %></h1>
        <p class="subtitle hero-subtitle"><%= t.home.heroSubtitle %></p>
        <div class="hero-buttons">
            <a href="/alerts" class="btn btn-primary btn-hero-primary"><i class="fas fa-bell"></i> <%= t.home.viewAlerts %></a>
            <a href="/subscribe" class="btn btn-secondary btn-hero-secondary"><i class="fas fa-envelope"></i> <%= t.home.subscribeCta %></a>
        </div>
    </div>
</section>

<section class="alerts-section">
    <div class="container">
        <h2 class="section-heading"><%= t.home.latestAlerts %></h2>
        <div class="alerts-grid">
            <% if (alerts && alerts.length > 0) { %>
                <% alerts.forEach(function(alert) { %>
                    <% var sev = String(alert.severity || '').toLowerCase(); %>
                    <a href="/alerts/<%= alert._id %>" class="alert-card <%= sev %>">
                        <div class="alert-card-media">
                            <%- include('partials/disaster-photo', { disasterType: alert.type, imgClass: '' }) %>
                            <span class="alert-card-badge <%= sev %>"><%= alert.severity %></span>
                        </div>
                        <div class="alert-card-body">
                            <h3><%= alert.title %></h3>
                            <p class="alert-card-desc"><%= alert.description %></p>
                            <div class="alert-meta location"><i class="fas fa-map-marker-alt"></i> <%= alert.location %></div>
                            <span class="alert-card-cta"><%= t.alerts.details %> <i class="fas fa-arrow-right"></i></span>
                        </div>
                    </a>
                <% }); %>
            <% } else { %>
                <p class="empty-inline"><%= t.home.noAlerts %></p>
            <% } %>
        </div>
    </div>
</section>

<section class="safety-section">
    <div class="container">
        <h2 class="section-heading"><%= t.home.safetyTitle %></h2>
        <div class="safety-grid home-safety-grid">
            <a href="/safety/Flood" class="guide-card flood">
                <%- include('partials/disaster-photo', { disasterType: 'Flood', imgClass: 'guide-card-thumb' }) %>
                <i class="fas fa-water" aria-hidden="true"></i>
                <h3><%= t.home.flood %></h3>
            </a>
            <a href="/safety/Earthquake" class="guide-card earthquake">
                <%- include('partials/disaster-photo', { disasterType: 'Earthquake', imgClass: 'guide-card-thumb' }) %>
                <i class="fas fa-house-crack" aria-hidden="true"></i>
                <h3><%= t.home.earthquake %></h3>
            </a>
            <a href="/safety/Fire" class="guide-card fire">
                <%- include('partials/disaster-photo', { disasterType: 'Fire', imgClass: 'guide-card-thumb' }) %>
                <i class="fas fa-fire" aria-hidden="true"></i>
                <h3><%= t.home.fire %></h3>
            </a>
            <a href="/safety/Cyclone" class="guide-card cyclone">
                <%- include('partials/disaster-photo', { disasterType: 'Cyclone', imgClass: 'guide-card-thumb' }) %>
                <i class="fas fa-wind" aria-hidden="true"></i>
                <h3><%= t.home.cyclone %></h3>
            </a>
        </div>
    </div>
</section>

<section class="subscribe-section">
    <div class="container subscribe-strip">
        <h2 class="section-heading"><%= t.home.subscribeTitle %></h2>
        <p class="subscribe-strip-text"><%= t.home.subscribeText %></p>
        <a href="/subscribe" class="btn btn-primary"><i class="fas fa-envelope"></i> <%= t.home.subscribeCta %></a>
    </div>
</section>

<%- include('partials/footer') %>
</body>
</html>
