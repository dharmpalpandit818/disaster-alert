<!DOCTYPE html>
<html lang="<%= lang %>">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= t.subscribe.title %> — <%= t.meta.siteTitle %></title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body>
<%- include('partials/navbar') %>

<div class="container main-content auth-wrap">
    <div class="auth-card">
        <h1><i class="fas fa-bell"></i> <%= t.subscribe.title %></h1>
        <% if (message === 'success') { %>
            <div class="alert success"><%= t.subscribe.success %></div>
        <% } else if (message === 'error') { %>
            <div class="alert error"><%= typeof error !== 'undefined' ? error : t.subscribe.error %></div>
        <% } %>
        <form action="/subscribe" method="POST" class="auth-form">
            <div class="form-group">
                <label for="email"><%= t.subscribe.email %> *</label>
                <input id="email" type="email" name="email" required>
            </div>
            <div class="form-group">
                <label for="phone"><%= t.subscribe.phone %></label>
                <input id="phone" type="tel" name="phone">
            </div>
            <div class="form-group">
                <label for="city"><%= t.subscribe.city %></label>
                <input id="city" type="text" name="city">
            </div>
            <div class="form-group">
                <label for="state"><%= t.subscribe.state %></label>
                <input id="state" type="text" name="state">
            </div>
            <div class="form-group">
                <label for="language"><%= t.subscribe.language %></label>
                <select id="language" name="language" class="lang-select">
                    <% supportedLangs.forEach(function(l) { %>
                        <option value="<%= l.code %>" <%= lang === l.code ? 'selected' : '' %>><%= l.label %></option>
                    <% }); %>
                </select>
            </div>
            <button type="submit" class="btn btn-primary btn-block"><%= t.subscribe.submit %></button>
        </form>
    </div>
</div>

<%- include('partials/footer') %>
</body>
</html>
