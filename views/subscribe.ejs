<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Subscribe - Disaster Alert</title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body>
    <!-- Navigation -->
    <nav class="navbar">
        <div class="container">
            <a href="/" class="logo">
                <i class="fas fa-exclamation-triangle"></i>
                <span>DisasterAlert</span>
            </a>
            <div class="nav-links">
                <a href="/"><i class="fas fa-home"></i> Home</a>
                <a href="/alerts"><i class="fas fa-bell"></i> Alerts</a>
                <a href="/safety"><i class="fas fa-shield-alt"></i> Safety</a>
                <a href="/subscribe" class="active"><i class="fas fa-envelope"></i> Subscribe</a>
            </div>
        </div>
    </nav>

    <div class="container main-content">
        <div class="form-container">
            <h2><i class="fas fa-bell"></i> Subscribe to Alerts</h2>
            
            <% if (message === 'success') { %>
                <div class="alert success">Successfully subscribed!</div>
            <% } else if (message === 'error') { %>
                <div class="alert error"><%= error %></div>
            <% } %>
            
            <form action="/subscribe" method="POST">
                <div class="form-group">
                    <label>Email *</label>
                    <input type="email" name="email" required>
                </div>
                <div class="form-group">
                    <label>Phone (for WhatsApp)</label>
                    <input type="tel" name="phone" placeholder="+91xxxxxxxxxx">
                </div>
                <div class="form-group">
                    <label>City</label>
                    <input type="text" name="city">
                </div>
                <div class="form-group">
                    <label>State</label>
                    <input type="text" name="state">
                </div>
                <button type="submit" class="btn btn-primary">Subscribe</button>
            </form>
        </div>
    </div>

    <footer class="footer">
        <div class="container">
            <p>&copy; 2024 Disaster Alert System</p>
        </div>
    </footer>
</body>
</html>