<nav class="navbar">
    <div class="container navbar-inner">
        <a href="<%= currentUser ? '/home' : '/auth/login' %>" class="logo">
            <i class="fas fa-exclamation-triangle"></i>
            <span><%= t.nav.brand %></span>
        </a>

        <button class="menu-toggle" type="button" aria-label="Toggle navigation" aria-expanded="false" aria-controls="navLinks">☰</button>
        <div class="menu-overlay"></div>

        <div class="nav-links sidebar" id="navLinks">
            <a href="/home" class="<%= currentPath === '/home' || currentPath === '/' ? 'active' : '' %>"><i class="fas fa-home"></i> <%= t.nav.home %></a>
            <a href="/alerts" class="<%= (typeof currentPath === 'string' && currentPath.startsWith('/alerts')) ? 'active' : '' %>"><i class="fas fa-bell"></i> <%= t.nav.alerts %></a>
            <a href="/safety" class="<%= (typeof currentPath === 'string' && currentPath.startsWith('/safety')) ? 'active' : '' %>"><i class="fas fa-shield-alt"></i> <%= t.nav.safety %></a>
            <a href="/subscribe" class="<%= currentPath === '/subscribe' ? 'active' : '' %>"><i class="fas fa-envelope"></i> <%= t.nav.subscribe %></a>

            <% if (currentUser) { %>
                <a href="/auth/logout"><i class="fas fa-sign-out-alt"></i> <%= t.nav.logout %></a>
            <% } else { %>
                <a href="/auth/login" class="<%= currentPath === '/auth/login' ? 'active' : '' %>"><i class="fas fa-sign-in-alt"></i> <%= t.nav.login %></a>
                <a href="/auth/register" class="<%= currentPath === '/auth/register' ? 'active' : '' %>"><i class="fas fa-user-plus"></i> <%= t.nav.register %></a>
            <% } %>
        </div>

        <div class="nav-tools">
            <label class="lang-label" for="nav-lang-select"><%= t.nav.language %></label>
            <select id="nav-lang-select" class="lang-select" aria-label="<%= t.nav.language %>"
                onchange="window.location.href='/lang/'+encodeURIComponent(this.value)">
                <% supportedLangs.forEach(function(l) { %>
                    <option value="<%= l.code %>" <%= lang === l.code ? 'selected' : '' %>><%= l.label %></option>
                <% }); %>
            </select>
        </div>

    </div>
</nav>

<script>
  (function () {
    const nav = document.getElementById('navLinks');
    const toggle = document.querySelector('.menu-toggle');
    const overlay = document.querySelector('.menu-overlay');
    if (!nav || !toggle || !overlay) return;

    const closeMenu = function () {
      nav.classList.remove('active');
      overlay.classList.remove('active');
      toggle.setAttribute('aria-expanded', 'false');
    };

    toggle.addEventListener('click', function () {
      const isOpen = nav.classList.toggle('active');
      overlay.classList.toggle('active', isOpen);
      toggle.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
    });

    overlay.addEventListener('click', closeMenu);
    nav.querySelectorAll('a').forEach(function (link) {
      link.addEventListener('click', closeMenu);
    });
  })();
</script>