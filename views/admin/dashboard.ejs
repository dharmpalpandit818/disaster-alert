<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>Admin Dashboard</title>
    <link rel="stylesheet" href="/css/admin.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body class="admin-page">
    <nav class="admin-nav">
        <div class="logo">DisasterAlert Admin</div>
        <div class="nav-links">
            <a href="/admin/dashboard" class="active">Dashboard</a>
            <a href="/admin/alerts">Alerts</a>
            <a href="/admin/subscribers">Subscribers</a>
            <a href="/admin/logout">Logout</a>
        </div>
    </nav>

    <div class="admin-container">
        <h1>Welcome, <%= user %></h1>
        
        <div class="stats-grid">
            <div class="stat-card">
                <i class="fas fa-bell"></i>
                <div class="stat-number"><%= stats.totalAlerts || 0 %></div>
                <div class="stat-label">Total Alerts</div>
            </div>
            <div class="stat-card">
                <i class="fas fa-exclamation-circle"></i>
                <div class="stat-number"><%= stats.activeAlerts || 0 %></div>
                <div class="stat-label">Active Alerts</div>
            </div>
            <div class="stat-card">
                <i class="fas fa-users"></i>
                <div class="stat-number"><%= stats.totalSubscribers || 0 %></div>
                <div class="stat-label">Subscribers</div>
            </div>
        </div>

        <h2>Recent Alerts</h2>
        <table class="data-table">
            <thead>
                <tr>
                    <th>Title</th>
                    <th>Type</th>
                    <th>Severity</th>
                    <th>Date</th>
                </tr>
            </thead>
            <tbody>
                <% if (stats.recentAlerts && stats.recentAlerts.length > 0) { %>
                    <% stats.recentAlerts.forEach(alert => { %>
                        <tr>
                            <td><%= alert.title %></td>
                            <td><%= alert.type %></td>
                            <td><%= alert.severity %></td>
                            <td><%= alert.createdAt.toLocaleDateString() %></td>
                        </tr>
                    <% }); %>
                <% } else { %>
                    <tr><td colspan="4">No alerts yet</td></tr>
                <% } %>
            </tbody>
        </table>
        
        <a href="/admin/alerts/create" class="btn btn-primary">Create New Alert</a>
    </div>
</body>
</html>