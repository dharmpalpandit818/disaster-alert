<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>Admin Login</title>
    <link rel="stylesheet" href="/css/admin.css">
    <link rel="shortcut icon" href="https://img.freepik.com/free-vector/globe-fire-melting_78370-7954.jpg?semt=ais_hybrid&w=740&q=80" type="image/x-icon">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body class="login-page">
    <div class="login-box">
        <h1><i class="fas fa-user-shield"></i> Admin Login</h1>
        
        <% if (error) { %>
            <div class="alert alert-danger"><%= error %></div>
        <% } %>
        
        <form action="/admin/login" method="POST">
            <div class="form-group">
                <label>Username</label>
                <input type="text" name="username" required value="admin">
            </div>
            <div class="form-group">
                <label>Password</label>
                <input type="password" name="password" required value="disaster123">
            </div>
            <button type="submit" class="btn btn-primary btn-block">Login</button>
        </form>
        
        <p style="text-align: center; margin-top: 1rem;">
            <a href="/"><i class="fas fa-arrow-left"></i> Back to Website</a>
        </p>
    </div>
</body>
</html>